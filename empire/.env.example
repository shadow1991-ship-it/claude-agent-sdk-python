# ════════════════════════════════════════════════════
#  SENTINEL GUARD EMPIRE — إعدادات البيئة
#  cp .env.example .env  ثم عدّل القيم
# ════════════════════════════════════════════════════

# ── Sentinel Guard API ──────────────────────────────
SENTINEL_API_URL=http://localhost:8000/api/v1
SENTINEL_EMAIL=admin@yourorg.com
SENTINEL_PASSWORD=your_secure_password_here

# ── Web Dashboard ────────────────────────────────────
DASHBOARD_SECRET=replace-with-random-64-char-string
DASHBOARD_PASSWORD=alhakim2026
DASHBOARD_PORT=5000

# ── Docker Model Runner (AI محلي — لا API key مطلوب) ─
# شغّل: docker model pull ai/deepseek-v4-flash
DOCKER_MODEL_RUNNER_URL=http://localhost:12434/engines/llama.cpp/v1
AI_MODEL_GENERAL=ai/deepseek-v4-flash
AI_MODEL_DEEP=ai/deepseek-v4-pro
AI_MODEL_FAST=ai/granite-4.0-nano
AI_ENABLED=true
AI_TIMEOUT=60

# ── Guardian ─────────────────────────────────────────
GUARDIAN_ROOT_PATH=..
