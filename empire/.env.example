#  انسخ هذا الملف إلى .env وعدّل القيم
#  cp .env.example .env
# ════════════════════════════════════════════════════

# ── Sentinel Guard API ──────────────────────────────
SENTINEL_API_URL=http://localhost:8000/api/v1
SENTINEL_EMAIL=admin@yourorg.com
SENTINEL_PASSWORD=your_secure_password_here

# ── Web Dashboard ────────────────────────────────────
DASHBOARD_SECRET=replace-with-random-64-char-string
DASHBOARD_PASSWORD=alhakim2026
DASHBOARD_PORT=5000

# ── Telegram Bot ─────────────────────────────────────
# احصل عليه من @BotFather مجاناً
TELEGRAM_BOT_TOKEN=your_bot_token_here
# معرّفك على تيليغرام (للحماية — اتركه فارغاً للسماح للجميع)
AL_HAKIM_CHAT_ID=

# ── Gemini AI (مجاني) ────────────────────────────────
# احصل عليه من: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ── Guardian ─────────────────────────────────────────
GUARDIAN_ROOT_PATH=..
