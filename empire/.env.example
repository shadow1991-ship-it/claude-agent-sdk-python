# ═══════════════════════════════════════════════════════
#  Market Intel + Sentinel Guard — إعدادات البيئة
#  انسخ هذا الملف: cp empire/.env.example empire/.env
#  ثم عدّل القيم بمفاتيحك الخاصة
# ═══════════════════════════════════════════════════════

# ─── Adanos Market Sentiment API ────────────────────────
# احصل على مفتاحك من: https://api.adanos.org
ADANOS_API_KEY=your_adanos_api_key_here
ADANOS_BASE_URL=https://api.adanos.org

# ─── كلمة مرور لوحة السوق (Market Intel) ──────────────
DASHBOARD_PASSWORD=market2026
MARKET_PORT=5001

# ─── Ollama (الذكاء المحلي) ─────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=phi3

# ─── Sentinel Guard API ─────────────────────────────────
SENTINEL_API_URL=http://localhost:8000/api/v1
SENTINEL_EMAIL=your@email.com
SENTINEL_PASSWORD=yourpassword
