# ════════════════════════════════════════════════════════════════
#  SENTINEL GUARD EMPIRE — إعدادات البيئة
#  cp .env.example .env  ثم عدّل القيم
# ════════════════════════════════════════════════════════════════

# ── Sentinel Guard API ───────────────────────────────────────────
SENTINEL_API_URL=http://localhost:8000/api/v1
SENTINEL_EMAIL=admin@yourorg.com
SENTINEL_PASSWORD=your_secure_password_here

# ── Web Dashboard ────────────────────────────────────────────────
# ولّد مفتاحاً: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
DASHBOARD_SECRET=replace-with-random-64-char-string
DASHBOARD_PASSWORD=alhakim2026
DASHBOARD_PORT=5000
HTTPS=false

# ── Gemini (اختياري — إذا أردت Gemini بدل النموذج المحلي) ────────
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_MODEL=gemini-2.0-flash

# ════════════════════════════════════════════════════════════════
#  AI — Docker Model Runner (محلي مجاني — لا API key مطلوب)
#  جميع النماذج تعمل محلياً — بياناتك لا تغادر جهازك
# ════════════════════════════════════════════════════════════════

# عنوان Docker Model Runner
DOCKER_MODEL_RUNNER_URL=http://localhost:12434/engines/llama.cpp/v1

# عام (dashboard chatbot) — سياق 1 مليون token
# docker model pull ai/deepseek-v4-flash
AI_MODEL_GENERAL=ai/deepseek-v4-flash

# عميق (تحليل أمني) — 1.6T params
# docker model pull ai/deepseek-v4-pro
AI_MODEL_DEEP=ai/deepseek-v4-pro

# سريع (AutoFixer) — 4B params / < 2 ثانية
# docker model pull ai/granite-4.0-nano
AI_MODEL_FAST=ai/granite-4.0-nano

# استدلال (logic chains) — 7B params من Xiaomi
# docker model pull ai/mimo-v2.5-pro
AI_MODEL_REASON=ai/mimo-v2.5-pro

# احتياطي (fallback) — إذا V4 غير متاح
# docker model pull ai/deepseek-v3-0324
AI_MODEL_FALLBACK=ai/deepseek-v3-0324

AI_ENABLED=true
AI_TIMEOUT=60

# ── Guardian ─────────────────────────────────────────────────────
GUARDIAN_ROOT_PATH=..
