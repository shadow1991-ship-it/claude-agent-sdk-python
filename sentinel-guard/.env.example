# ════════════════════════════════════════════════════════════════
#  SENTINEL GUARD — إعدادات البيئة الكاملة
#  cp .env.example .env  ثم عدّل القيم المطلوبة
# ════════════════════════════════════════════════════════════════

# ── التطبيق ──────────────────────────────────────────────────────
APP_NAME=Sentinel Guard
DEBUG=false

# ── قاعدة البيانات — لا تغيّر إذا تستخدم docker-compose ─────────
DATABASE_URL=postgresql+asyncpg://sentinel:sentinel@db:5432/sentinel_db

# ── Redis / Celery — لا تغيّر إذا تستخدم docker-compose ─────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# ── الأمان — يجب تغيير SECRET_KEY قبل الإنتاج ───────────────────
# ولّد مفتاحاً قوياً:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-a-strong-random-secret-key-minimum-64-chars

ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Shodan (اختياري — للـ OSINT السلبي) ──────────────────────────
# احصل على مفتاح مجاني من: https://account.shodan.io
SHODAN_API_KEY=your_shodan_api_key_here

# ── RSA (تُولَّد تلقائياً عند أول تشغيل) ─────────────────────────
RSA_PRIVATE_KEY_PATH=keys/private.pem
RSA_PUBLIC_KEY_PATH=keys/public.pem

# ── CORS — حدّد دومينك في الإنتاج ────────────────────────────────
# CORS_ORIGINS=https://yourdomain.com,https://dashboard.yourdomain.com
CORS_ORIGINS=*
ALLOWED_HOSTS=*

# ── حدود الفحص ───────────────────────────────────────────────────
MAX_CONCURRENT_SCANS=5
SCAN_TIMEOUT_SECONDS=300

# ── Rate Limiting ─────────────────────────────────────────────────
RATE_LOGIN=5/minute
RATE_SCAN=10/minute
RATE_ASSETS=30/minute

# ════════════════════════════════════════════════════════════════
#  AI — Docker Model Runner (محلي مجاني — لا API key مطلوب)
# ════════════════════════════════════════════════════════════════

# عنوان Docker Model Runner
# داخل container:  http://model-runner.docker.internal:12434/engines/llama.cpp/v1
# من المضيف:       http://localhost:12434/engines/llama.cpp/v1
DOCKER_MODEL_RUNNER_URL=http://localhost:12434/engines/llama.cpp/v1

# تفعيل/تعطيل AI (اجعله false إذا لم تُحمّل أي نموذج)
AI_ENABLED=true
AI_TIMEOUT=60

# ── توجيه المهام — كل نموذج لمهمته ──────────────────────────────
#
# سريع < 2ث  : AutoFixer، توليد كود الإصلاح
# سحب: docker model pull ai/granite-4.0-nano
AI_MODEL_FAST=ai/granite-4.0-nano

# عميق < 30ث : تحليل Dockerfile، CVE reasoning، SBOM
# سحب: docker model pull ai/deepseek-v4-pro
AI_MODEL_DEEP=ai/deepseek-v4-pro

# عام < 15ث  : Dashboard chatbot، SSE Q&A، سياق 1M token
# سحب: docker model pull ai/deepseek-v4-flash
AI_MODEL_GENERAL=ai/deepseek-v4-flash

# استدلال < 10ث: تحليل منطقي متعدد الخطوات، attack chains (7B محلي خفيف)
# سحب: docker model pull ai/mimo-v2.5-pro
AI_MODEL_REASON=ai/mimo-v2.5-pro

# احتياطي < 20ث: إذا V4 غير متاح على جهازك
# سحب: docker model pull ai/deepseek-v3-0324
AI_MODEL_FALLBACK=ai/deepseek-v3-0324

# ── Lambda Mode (اختياري — للنشر على AWS) ─────────────────────────
LAMBDA_MODE=false
